{
    "name": "dalbeirdev/connectwise-psa-osticket",
    "description": "ConnectWise PSA <-> osTicket integration platform (standalone, multi-PSA ready)",
    "type": "project",
    "license": "GPL-2.0-only",
    "require": {
        "php": ">=8.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": "php -S 127.0.0.1:8085 -t public public/index.php"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
