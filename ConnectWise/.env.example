# ConnectWise PSA <-> osTicket Integration Platform
# Copy to .env and fill in. NEVER commit .env.

APP_NAME="ConnectWise Integration"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8085
# 32+ random characters; used for CSRF/session hardening.
APP_KEY=

# Platform database (integration's own tables)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=connectwise_integration
DB_USERNAME=root
DB_PASSWORD=

# ConnectWise PSA (can also be managed on the Settings page once installed)
CW_SITE_URL=https://na.myconnectwise.net
CW_COMPANY_ID=
CW_PUBLIC_KEY=
CW_PRIVATE_KEY=
CW_CLIENT_ID=
CW_API_VERSION=3.0

# osTicket
OST_URL=http://localhost/osticket
OST_API_KEY=
# osTicket database (required for operations its API does not expose)
OST_DB_HOST=127.0.0.1
OST_DB_PORT=3306
OST_DB_DATABASE=osticket
OST_DB_USERNAME=root
OST_DB_PASSWORD=
OST_DB_PREFIX=ost_

LOG_LEVEL=info
